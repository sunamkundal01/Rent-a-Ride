# ─────────────────────────────────────────────
#  Rent a Ride — Backend environment variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas or local)
mongo_uri=mongodb+srv://<user>:<password>@cluster.mongodb.net/rentaride

# JWT secrets — use long random strings (e.g. `openssl rand -hex 32`)
ACCESS_TOKEN=
REFRESH_TOKEN=

# Cloudinary (vehicle image/video uploads) — https://cloudinary.com/console
CLOUD_NAME=
API_KEY=
API_SECRET=

# Razorpay test-mode keys — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# Email (Gmail address + 16-char Gmail App Password, no spaces)
EMAIL_HOST=
EMAIL_PASSWORD=

# Optional: server port (defaults to 3000)
# PORT=3000
