# ─────────────────────────────────────────────
#  Rent a Ride — Frontend (Vite) environment variables
#  Copy this file to "client/.env" and fill in real values.
#  Only VITE_ vars are exposed to the browser (do NOT put secrets here).
# ─────────────────────────────────────────────

# Backend base URL.
#  - Local dev:  http://localhost:3000
#  - Production: your deployed backend URL (e.g. https://rent-a-ride-api.onrender.com)
VITE_PRODUCTION_BACKEND_URL=http://localhost:3000

# Firebase Web API key (Google sign-in) — from your Firebase web app config
VITE_FIREBASE_API_KEY=

# Razorpay public key id — same value as backend RAZORPAY_KEY_ID
VITE_RAZORPAY_KEY_ID=
